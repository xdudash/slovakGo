# ─── Vite / Client ───────────────────────────────────────────────
# Copy to .env.local and fill in values.

# Firebase Web App config (Project settings → Your apps → Web)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# VAPID public key (Project settings → Cloud Messaging → Web push certificates)
VITE_FIREBASE_VAPID_KEY=

# ─── PHP Backend ─────────────────────────────────────────────────
# Set these as server environment variables (cPanel → Software → PHP → ENV or .htaccess SetEnv)

# Firebase project ID (same as VITE_FIREBASE_PROJECT_ID)
# FIREBASE_PROJECT_ID=

# Absolute path to the service account JSON file (keep outside public_html!)
# FIREBASE_SA_JSON=/home/user/private/firebase-sa.json

# Secret for cron endpoints (/api/index.php/cron/push?key=...)
# CRON_SECRET=change-me-to-a-long-random-string

# Public URL of the app — used in password-reset email links
# APP_URL=https://yourdomain.com

# From-address for transactional emails (forgot-password)
# MAIL_FROM=noreply@yourdomain.com

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=https://yourdomain.com

# ─── Stripe ──────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys
# STRIPE_SECRET_KEY=sk_live_...

# Price ID from Stripe Dashboard → Products → your product → price
# STRIPE_PRICE_ID=price_1TjESC6bLes2FwwHFWKVGUdx

# Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# STRIPE_WEBHOOK_SECRET=whsec_...

# Set to 1 if the app is behind a trusted reverse-proxy that sets X-Forwarded-For.
# Leave unset or 0 for direct Apache/Nginx deployments (prevents IP spoofing).
# TRUSTED_PROXY=0

# ─── Cron setup (cPanel → Cron Jobs) ─────────────────────────────
# Push reminders — EVERY HOUR (each user notified at their chosen reminderTime):
# 0 * * * * curl -s "https://yourdomain.com/api/index.php/cron/push?key=YOUR_CRON_SECRET" > /dev/null
#
# Weekly report push — every Sunday at 18:00 UTC:
# 0 18 * * 0 curl -s "https://yourdomain.com/api/index.php/cron/weekly?key=YOUR_CRON_SECRET" > /dev/null
#
# SQLite backup — daily at 03:00 UTC (keeps 7 rolling daily backups):
# 0 3 * * * curl -s "https://yourdomain.com/api/index.php/cron/backup?key=YOUR_CRON_SECRET" > /dev/null
# — OR — use scripts/backup.sh directly if you have SSH/cPanel file access
