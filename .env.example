# ─── Vite / Client ───────────────────────────────────────────────
# Copy to .env.local and fill in values.

# Firebase Web App config (Project settings → Your apps → Web)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# VAPID public key (Project settings → Cloud Messaging → Web push certificates)
VITE_FIREBASE_VAPID_KEY=

# ─── Node.js / Vercel Backend ────────────────────────────────────
# Set these in Vercel Dashboard → Project → Settings → Environment Variables
# For local dev: copy to .env.local (already gitignored via *.local)

# Turso (libsql) cloud database
# Create a free DB at https://turso.tech  →  turso db create slovak-life
# TURSO_DATABASE_URL=libsql://slovak-life-<username>.turso.io
# TURSO_AUTH_TOKEN=eyJ...

# JWT signing secret — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# JWT_SECRET=change-me-to-a-64-char-random-hex-string

# Public URL of the app — used in password-reset email links
# APP_URL=https://www.slovakgo.sk

# From-address for transactional emails — must be a verified domain in Resend
# MAIL_FROM=noreply@slovakgo.sk

# Resend.com API key for sending password reset emails (required in production)
# Sign up free at https://resend.com → API Keys → Create key → paste here
# RESEND_API_KEY=re_...

# Firebase Cloud Messaging server key for push notifications (optional)
# Firebase Console → Project settings → Cloud Messaging → Server key
# FIREBASE_SERVER_KEY=AAAA...

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=https://yourdomain.vercel.app

# ─── Stripe ──────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys
# STRIPE_SECRET_KEY=sk_live_...

# Price ID from Stripe Dashboard → Products → your product → price
# STRIPE_PRICE_ID=price_1TjESC6bLes2FwwHFWKVGUdx

# Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Create webhook: https://dashboard.stripe.com/webhooks → Add endpoint → https://yourapp.vercel.app/api/billing/webhook
# Events to listen: checkout.session.completed, customer.subscription.deleted
# STRIPE_WEBHOOK_SECRET=whsec_...
