# ─── Vite / Client ───────────────────────────────────────────────
# Copy to .env.local and fill in values.

# Firebase Web App config (Project settings → Your apps → Web)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# VAPID public key (Project settings → Cloud Messaging → Web push certificates)
VITE_FIREBASE_VAPID_KEY=

# ─── PHP Backend ─────────────────────────────────────────────────
# Set these as server environment variables (cPanel → Software → PHP → ENV or .htaccess SetEnv)

# Firebase project ID (same as VITE_FIREBASE_PROJECT_ID)
# FIREBASE_PROJECT_ID=

# Absolute path to the service account JSON file (keep outside public_html!)
# FIREBASE_SA_JSON=/home/user/private/firebase-sa.json

# Secret for the daily cron endpoint (/api/index.php/cron/push?key=...)
# CRON_SECRET=change-me-to-a-long-random-string

# Comma-separated list of allowed CORS origins
# ALLOWED_ORIGINS=https://yourdomain.com

# ─── Cron setup (cPanel → Cron Jobs) ─────────────────────────────
# Daily at 20:00 UTC (streak + scenario push):
# 0 20 * * * curl -s "https://yourdomain.com/api/index.php/cron/push?key=YOUR_CRON_SECRET" > /dev/null
#
# Weekly on Sunday at 18:00 UTC (weekly report push):
# 0 18 * * 0 curl -s "https://yourdomain.com/api/index.php/cron/weekly?key=YOUR_CRON_SECRET" > /dev/null
