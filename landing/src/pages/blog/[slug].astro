---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, updatedDate, keywords } = post.data;
const slug = post.slug;

const dateStr = pubDate.toLocaleDateString('uk-UA', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate ?? pubDate).toISOString(),
  "keywords": keywords?.join(', '),
  "author": {
    "@type": "Organization",
    "name": "SlovakGO",
    "url": "https://www.slovakgo.sk",
  },
  "publisher": {
    "@type": "Organization",
    "name": "SlovakGO",
    "logo": { "@type": "ImageObject", "url": "https://www.slovakgo.sk/logosk.jpg" },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://www.slovakgo.sk/blog/${slug}`,
  },
};
---

<Base title={`${title} — SlovakGO`} {description} {keywords} schema={schema}>
  <main>
    <div class="container">
      <article class="post-page">
        <a href="/blog" class="post-back">← Всі статті</a>

        <header class="post-header">
          <time datetime={pubDate.toISOString()}>{dateStr}</time>
          <h1>{title}</h1>
          <p class="post-desc">{description}</p>
        </header>

        <div class="prose">
          <Content />
        </div>

        <div class="post-cta">
          <div class="post-cta-inner">
            <p class="post-cta-label">Вчи словацьку прямо зараз</p>
            <h2>Спробуй SlovakGO безкоштовно</h2>
            <p>15 хвилин на день — і за 90 днів ти вільно спілкуєшся у Словаччині. Без кредитної картки.</p>
            <a href="https://app.slovakgo.sk/register" class="btn btn-primary btn-lg" rel="noopener">
              Почати безкоштовно
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </article>
    </div>
  </main>
</Base>
