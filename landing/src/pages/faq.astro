---
import Base from '../layouts/Base.astro';
import FaqBlock from '../components/FaqBlock.astro';
import faqs from '../data/faq.json';
---

<Base
  title="Часті запитання — SlovakGO"
  description="Відповіді на найпоширеніші запитання про SlovakGO та вивчення словацької мови для українців у Словаччині: час навчання, рівні CEFR, документи, робота."
>
  <main>
    <div class="container">
      <div class="faq-page">
        <header class="faq-page-header">
          <h1>Часті запитання</h1>
          <p>Відповіді на найпоширеніші запитання від українців, що адаптуються до життя у Словаччині та вивчають словацьку.</p>
        </header>

        <FaqBlock items={faqs} />

        <div class="faq-contact-block">
          <h2 class="faq-contact-title">Не знайшов відповідь?</h2>
          <p class="faq-contact-text">Напиши нам — відповідаємо протягом 24 годин.</p>
          <a href="mailto:support@slovakgo.sk" class="btn btn-primary">
            Написати в підтримку
          </a>
          <p class="faq-contact-email">
            або одразу на <a href="mailto:support@slovakgo.sk">support@slovakgo.sk</a>
          </p>
        </div>
      </div>
    </div>
  </main>
</Base>
