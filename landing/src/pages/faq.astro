---
import Base from '../layouts/Base.astro';
import FaqBlock from '../components/FaqBlock.astro';
import faqs from '../data/faq.json';
---

<Base
  title="Часті запитання — SlovakGO"
  description="Відповіді на найпоширеніші запитання про SlovakGO та вивчення словацької мови для українців у Словаччині: час навчання, рівні CEFR, документи, робота."
>
  <main>
    <div class="container">
      <div class="faq-page">
        <header class="faq-page-header">
          <h1>Часті запитання</h1>
          <p>Відповіді на найпоширеніші запитання від українців, що адаптуються до життя у Словаччині та вивчають словацьку.</p>
        </header>

        <FaqBlock items={faqs} />

        <div style="margin-top:64px; padding-top:48px; border-top:1px solid var(--border);">
          <p style="color:var(--muted); margin-bottom:16px;">Не знайшли відповідь?</p>
          <a href="mailto:hello@slovakgo.sk" class="btn btn-ghost">Написати нам</a>
        </div>
      </div>
    </div>
  </main>
</Base>
