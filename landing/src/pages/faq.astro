---
import Base from '../layouts/Base.astro';

const faqs = [
  {
    q: "Скільки часу потрібно, щоб вивчити базову словацьку мову?",
    a: "Більшість учнів досягають рівня <strong>A2 (виживання)</strong> за 3–4 місяці при 15 хвилинах щоденних занять. Для рівня <strong>B1 (робочий)</strong> потрібно 6–9 місяців. Українськомовним учням легше — спільна слов'янська база прискорює засвоєння лексики приблизно на 30% порівняно з носіями романських або германських мов.",
  },
  {
    q: "Чи схожа словацька мова на українську?",
    a: "Так — обидві є слов'янськими мовами та мають 30–40% спільної базової лексики. Такі слова як <em>voda</em> (вода), <em>mesto</em> (місто), <em>sestra</em> (сестра), <em>dobrý</em> (добрий) українці розуміють без перекладу. Основні відмінності — у вимові (латинський алфавіт, довгі голосні) та деяких граматичних формах. Загалом словацька є однією з найлегших іноземних мов для українців.",
  },
  {
    q: "Який рівень словацької потрібен для роботи в Словаччині?",
    a: "Для більшості виробничих та логістичних позицій достатньо рівня <strong>A2</strong>. Для офісної роботи або позицій з клієнтами потрібен <strong>B1–B2</strong>. Шкала CEFR: A1 (базові фрази) → A2 (виживання) → B1 (робочий рівень) → B2 (вільне спілкування). Úrad práce (Центр зайнятості) може запропонувати безкоштовні мовні курси для зареєстрованих безробітних.",
  },
  {
    q: "Як безкоштовно вивчити словацьку онлайн?",
    a: "SlovakGO пропонує безкоштовний Basic-план з доступом до всіх рівнів навчання від A0 до B2. Щоденні уроки (10–15 хвилин) доступні без оплати та без кредитної картки. Безкоштовний план включає систему XP, серій та таблицю лідерів. Платний Plus (€9.99/міс) додає офлайн доступ та безлімітні серця.",
  },
  {
    q: "Чи потрібне знання словацької для отримання тимчасового проживання?",
    a: "Для отримання <em>prechodný pobyt</em> (тимчасового проживання) базове знання словацької не є обов'язковим, але суттєво допомагає при спілкуванні з <strong>Cudzinecká polícia</strong> (Відділом у справах іноземців). Для постійного проживання (<em>trvalý pobyt</em>) після 5 років може знадобитися іспит на рівень A2.",
  },
  {
    q: "Як зареєструватися в Словаччині як іноземець?",
    a: "Потрібно звернутися до <strong>Cudzinecká polícia</strong> за місцем проживання. Необхідні: паспорт, договір оренди житла або лист від роботодавця, заповнена анкета та фото. SlovakGO має спеціальний урок з лексикою для цього процесу, включаючи типові запитання офіцерів та правильні відповіді.",
  },
  {
    q: "Чи потрібна словацька для медичного обслуговування?",
    a: "Більшість лікарів у великих містах Словаччини (Bratislava, Košice, Prešov) розуміють базову англійську, проте знання словацьких медичних термінів суттєво пришвидшує візит. SlovakGO містить окремий урок <strong>«У лікаря»</strong> з фразами для опису симптомів, розуміння діагнозу та рецепту в аптеці (<em>lekáreň</em>).",
  },
  {
    q: "Чи можна вчити словацьку без інтернету?",
    a: "Так — користувачі SlovakGO Plus можуть завантажувати уроки для офлайн вивчення. Це зручно під час поїздок потягом Bratislava–Košice або в районах зі слабким сигналом. Прогрес синхронізується автоматично при появі інтернету.",
  },
  {
    q: "Яка різниця між словацькою та чеською мовами?",
    a: "Словацька (Slovenčina) і чеська (Čeština) — близькі, але різні мови. Носії взаємно розуміють одне одного приблизно на 80–85%. Основні відмінності: деякі слова звучать інакше (<em>mlieko</em> SK vs <em>mléko</em> CZ для «молока»), є відмінності у вимові та деяких граматичних формах. Якщо ви знаєте чеську — вам значно легше. Якщо ні — вивчайте словацьку напряму, не через чеську.",
  },
  {
    q: "Що таке рівні A1, A2, B1, B2 і що вони означають для мене?",
    a: "CEFR (Загальноєвропейські рекомендації з мовної освіти) — міжнародна шкала від A1 до C2. Для українців у Словаччині: <strong>A1</strong> — базові фрази та вітання; <strong>A2</strong> — щоденне виживання, магазин, транспорт, оренда; <strong>B1</strong> — робота, документи, вільна розмова з колегами; <strong>B2</strong> — офісна робота, управлінські позиції, ділові переговори. SlovakGO веде від A0 до B2.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.a.replace(/<[^>]+>/g, ''),
    },
  })),
};
---

<Base
  title="Часті запитання — SlovakGO"
  description="Відповіді на найпоширеніші запитання про SlovakGO та вивчення словацької мови для українців у Словаччині: час навчання, рівні CEFR, документи, робота."
  schema={schema}
>
  <main>
    <div class="container">
      <div class="faq-page">
        <header class="faq-page-header">
          <h1>Часті запитання</h1>
          <p>Відповіді на найпоширеніші запитання від українців, що адаптуються до життя у Словаччині та вивчають словацьку.</p>
        </header>

        <div class="faq-accordion" role="list">
          {faqs.map((faq, i) => (
            <details class="faq-accordion-item" role="listitem">
              <summary>{faq.q}</summary>
              <div class="faq-answer" set:html={faq.a} />
            </details>
          ))}
        </div>

        <div style="margin-top:64px; padding-top:48px; border-top:1px solid var(--border);">
          <p style="color:var(--muted); margin-bottom:16px;">Не знайшли відповідь?</p>
          <a href="mailto:hello@slovakgo.sk" class="btn btn-ghost">Написати нам</a>
        </div>
      </div>
    </div>
  </main>
</Base>
